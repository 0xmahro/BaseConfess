# ── Supabase ───────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── WalletConnect ──────────────────────────────────────────────────────────────
# Get a free Project ID from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ── MiniApp ─────────────────────────────────────────────────────────────────────
# Your production URL (used in farcaster.json manifest and og tags)
NEXT_PUBLIC_URL=https://baseconfess.fun

# ── Love Meter ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_LOVE_METER_ADDRESS=0x8765bd20c3cC2bCa9e9E42f40447FC0D09e54FA3
# Optional: contract creation block on Base (Basescan → Contract → Details). Needed to count tests if the contract has no totalTests() yet.
# NEXT_PUBLIC_LOVE_METER_DEPLOY_BLOCK=12345678
